<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:descendantFocusability="beforeDescendants"
    tools:context=".Verificacion2FA">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/txt_titulo_2fa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Verificación 2FA"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:fontFamily="@font/inter_font"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btn_back_2fa"
            android:layout_width="38dp"
            android:layout_height="41dp"
            android:layout_marginStart="10dp"
            android:layout_marginTop="3dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintHorizontal_bias="0.1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/boton_back" />

        <ImageView
            android:id="@+id/img_logo_2fa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txt_titulo_2fa"
            app:srcCompat="@drawable/icono_r_c" />

        <TextView
            android:id="@+id/txt_2fa_titulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:text="Confirma tu identidad"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/inter_font"
            android:textStyle="bold"
            android:textSize="24sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/img_logo_2fa" />

        <TextView
            android:id="@+id/txt_2fa_subtitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:gravity="center"
            android:text="Hemos enviado un código de verificación \na tu correo electrónico. Ingrésalo \npara continuar."
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/inter_font"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txt_2fa_titulo" />

        <TextView
            android:id="@+id/txt_email_2fa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/azul_1"
            android:fontFamily="@font/inter_font"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txt_2fa_subtitulo" />

        <TextView
            android:id="@+id/label_codigo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/inter_font"
            android:text="Código de verificación"
            android:textColor="@color/gris_2"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txt_email_2fa" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_codigo_2fa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="24dp"
            app:boxBackgroundColor="@color/bg_card"
            app:boxBackgroundMode="filled"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusTopStart="16dp"
            app:boxStrokeColor="@android:color/transparent"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/label_codigo"
            app:startIconDrawable="@drawable/lock"
            app:startIconTint="@color/gris_1">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/entrada_codigo_2fa"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@null"
                android:hint="000000"
                android:inputType="number"
                android:maxLength="6"
                android:textColor="@color/text_primary"
                android:textColorHint="#8A94A6"
                android:letterSpacing="0.3"
                android:textSize="20sp"
                android:gravity="center" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_verificar_2fa"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="30dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_boton_ingresar"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/inter_font"
            android:text="Verificar"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_codigo_2fa"
            app:rippleColor="@android:color/transparent" />

        <TextView
            android:id="@+id/btn_reenviar_2fa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/inter_font"
            android:text="Reenviar código"
            android:textColor="@color/azul_1"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_verificar_2fa" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
