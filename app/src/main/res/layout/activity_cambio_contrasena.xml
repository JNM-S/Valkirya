<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:descendantFocusability="beforeDescendants"
    tools:context=".CambioContrasena">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- HEADER -->
        <TextView
            android:id="@+id/txt_titulo_cambio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Cambia tu contraseña"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btn_back_cambio"
            android:layout_width="38dp"
            android:layout_height="41dp"
            android:layout_marginStart="10dp"
            android:layout_marginTop="3dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintHorizontal_bias="0.1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/boton_back" />

        <!-- LOGO PRINCIPAL -->
        <ImageView
            android:id="@+id/img_escudo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.497"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txt_titulo_cambio"
            app:srcCompat="@drawable/icono_r_c" />

        <!-- TÍTULO GRANDE -->
        <TextView
            android:id="@+id/txt_cambio_titulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:text="Cambia Tu Contraseña"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/inter_font"
            android:textStyle="bold"
            android:textSize="24sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/img_escudo" />

        <!-- SUBTÍTULO -->
        <TextView
            android:id="@+id/txt_cambio_subtitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:gravity="center"
            android:text="Introduce tu correo electrónico para recibir \nlas instrucciones para el cambio de tu \ncuenta."
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/inter_font"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txt_cambio_titulo" />

        <!-- LABEL CORREO -->
        <TextView
            android:id="@+id/label_email_cambio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/inter_font"
            android:text="Correo electrónico"
            android:textColor="@color/gris_2"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txt_cambio_subtitulo" />

        <!-- CAMPO CORREO -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_email_cambio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="24dp"
            app:boxBackgroundColor="@color/bg_card"
            app:boxBackgroundMode="filled"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusTopStart="16dp"
            app:boxStrokeColor="@android:color/transparent"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.05"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/label_email_cambio"
            app:startIconDrawable="@drawable/email"
            app:startIconTint="@color/gris_1">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/entrada_email_cambio"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@null"
                android:hint="ejemplo@valkyria.com"
                android:inputType="textEmailAddress"
                android:textColor="@color/text_primary"
                android:textColorHint="#8A94A6" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- BOTÓN ENVIAR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_enviar_cambio"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="30dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_boton_ingresar"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/inter_font"
            android:text="Enviar Instrucciones"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_email_cambio"
            app:rippleColor="@android:color/transparent" />

        <!-- LINK VOLVER -->
        <TextView
            android:id="@+id/link_volver_config"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/inter_font"
            android:text="Volver a la configuración"
            android:textColor="@color/azul_1"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_enviar_cambio" />

        <!-- BRANDING -->
        <ImageView
            android:id="@+id/img_logo_cambio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/link_volver_config"
            app:srcCompat="@drawable/icono_inicio_sesion" />

        <TextView
            android:id="@+id/txt_branding_valkyria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_font"
            android:text="Valkyria"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/img_logo_cambio" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
