<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Valkyria" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:fitsSystemWindows">true</item>
        <item name="colorPrimary">@color/azul_1</item>
        <item name="colorSecondary">@color/azul_1</item>
        <item name="colorControlActivated">@color/azul_1</item>
        <!-- Diálogos en modo oscuro -->
        <item name="materialAlertDialogTheme">@style/DarkAlertDialog</item>
        <item name="alertDialogTheme">@style/DarkAlertDialog</item>
        <!-- Colores de texto adaptativos -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>

    <style name="Theme.Valkyria" parent="Base.Theme.Valkyria" />

    <!-- Estilo Switch igual al de Ajustes -->
    <style name="SwitchAjustes" parent="Theme.MaterialComponents">
        <item name="colorPrimary">@color/azul_1</item>
        <item name="colorControlActivated">@color/azul_1</item>
        <item name="colorSwitchThumbNormal">@color/blanco</item>
        <item name="android:colorForeground">#1A2238</item>
    </style>

    <!-- Estilo de diálogo oscuro consistente con la app -->
    <style name="DarkTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/text_secondary</item>
        <item name="boxBackgroundColor">@color/bg_input</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="errorTextColor">#FF5722</item>
        <item name="boxStrokeErrorColor">#FF5722</item>
    </style>
    <style name="DarkAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:background">@color/bg_card</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="colorPrimary">@color/azul_1</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="materialAlertDialogTitleTextStyle">@style/DarkAlertDialog.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/DarkAlertDialog.Body</item>
    </style>

    <style name="DarkAlertDialog.Title" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">@font/inter_font</item>
    </style>

    <style name="DarkAlertDialog.Body" parent="MaterialAlertDialog.Material3.Body.Text">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">@font/inter_font</item>
    </style>

</resources>